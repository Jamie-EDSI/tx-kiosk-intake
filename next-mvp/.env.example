NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key

# JSON array. Times are local to the kiosk browser for MVP simplicity.
NEXT_PUBLIC_BUSINESS_HOURS=[{"days":[1,2,3,4,5],"open":"08:30","close":"17:00"}]
NEXT_PUBLIC_KIOSK_DEVICE_ID=00000000-0000-0000-0000-000000000000

# Device token is sent to the server from the kiosk. Treat it as a scoped, rotatable device credential.
NEXT_PUBLIC_KIOSK_DEVICE_TOKEN=replace-with-registered-device-token
CALL_RING_TIMEOUT_SECONDS=25

# Set this to true for same-machine local testing without Supabase.
NEXT_PUBLIC_LOCAL_DEMO=true
